{
  "type": "record",
  "name": "DetectionAlert",
  "namespace": "drishti.alerts",
  "fields": [
    {"name": "rule_name",     "type": "string"},
    {"name": "severity",      "type": "string"},
    {"name": "timestamp",     "type": "string"},
    {"name": "user_name",     "type": ["null", "string"], "default": null},
    {"name": "src_ip",        "type": ["null", "string"], "default": null},
    {"name": "matched_event", "type": "string"}
  ]
}